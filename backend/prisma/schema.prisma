generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  senha String
}

model Produto {
  id        Int     @id @default(autoincrement())
  nome      String
  categoria String?
  preco     Float
  custo     Float?
  estoque   Int
}

model Cliente {
  id       Int     @id @default(autoincrement())
  nome     String
  email    String  @unique
  telefone String?
  cpf      String?
}

model Venda {
  id    Int      @id @default(autoincrement())
  data  DateTime @default(now())
  total Float
}
